# Default: groq (fast free tier; get key at https://console.groq.com)
LLM_PROVIDER=groq
GROQ_API_KEY=
# Optional override — see Groq console for current model IDs
# GROQ_MODEL=llama-3.3-70b-versatile

# --- xAI Grok (https://console.x.ai — OpenAI-compatible API)
# LLM_PROVIDER=xai
# XAI_API_KEY=
# Optional — use a model id from xAI docs / console (examples: grok-2-latest, grok-3)
# XAI_MODEL=grok-2-latest

# --- Alternative: Google Gemini (https://aistudio.google.com)
# LLM_PROVIDER=gemini
# GOOGLE_GENERATIVE_AI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# --- Alternative: OpenRouter (https://openrouter.ai)
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
